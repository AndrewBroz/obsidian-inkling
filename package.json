{
	"name": "obsidian-inkling",
	"version": "0.4.0",
	"type": "module",
	"description": "A CriticMarkup plugin for Obsidian",
	"main": "main.js",
	"scripts": {
		"dev": "bun scripts/build/esbuild.config.ts development && obsidian plugin:reload id=inkling",
		"build": "bun run tsc -noEmit -skipLibCheck && bun scripts/build/esbuild.config.ts production",
		"build:dev": "bun run tsc -noEmit -skipLibCheck && bun scripts/build/esbuild.config.ts development",
		"build:dev:hr": "bun run tsc -noEmit -skipLibCheck && bun scripts/build/esbuild.config.ts development && obsidian plugin:reload id=inkling",
		"lint": "bun eslint src/",
		"format": "bun dprint fmt",
		"test": "jest --verbose",
		"release-patch": "bun run scripts/release/bump-version.ts --type patch",
		"release-minor": "bun run scripts/release/bump-version.ts --type minor",
		"release-major": "bun run scripts/release/bump-version.ts --type major",
		"release-rc": "bun run scripts/release/bump-version.ts --rc",
		"postinstall": "bun run scripts/postinstall.ts"
	},
	"keywords": [],
	"author": "Andrew Brož (https://github.com/AndrewBroz)",
	"contributors": [
		"kometenstaub (https://github.com/kometenstaub)",
		"Fevol (https://github.com/Fevol)"
	],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^10.0.0",
		"@lezer/generator": "^1.8.0",
		"@tsconfig/svelte": "^5.0.8",
		"@types/bun": "^1.3.11",
		"@types/diff-match-patch": "^1.0.36",
		"@types/jest": "^30",
		"@types/node": "^26.0.0",
		"builtin-modules": "^5.0.0",
		"commander": "^15.0.0",
		"dprint": "^0.55.0",
		"esbuild": "^0.28.0",
		"esbuild-sass-plugin": "^3.7.0",
		"esbuild-svelte": "^0.9.4",
		"eslint": "^10.6.0",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"jest": "^30",
		"jest-environment-jsdom": "^30",
		"jest-expect-message": "^1.1.3",
		"jsdom": "^26.1.0",
		"obsidian": "^1.12.3",
		"obsidian-typings": "^5.20.0",
		"svelte": "^5.55.2",
		"svelte-eslint-parser": "^1.8.0",
		"svelte-preprocess": "^6.0.3",
		"ts-jest": "^29.4.9",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.63.0"
	},
	"dependencies": {
		"@codemirror/language": "github:fevol-forks/cm-language",
		"@codemirror/search": "^6.5.0",
		"@fevol/lang-criticmarkup": "^2.1.0",
		"@flatten-js/interval-tree": "^1.1.4",
		"diff-match-patch": "^1.0.5",
		"localforage": "^1.10.0",
		"localforage-getitems": "github:conversejs/localForage-getItems",
		"localforage-setitems": "^1.4.0",
		"monkey-around": "^3.0.0",
		"svelty-picker": "^6.1.6"
	},
	"overrides": {
		"@lezer/common": "1.2.3",
		"@codemirror/state": "6.5.0",
		"@codemirror/view": "6.38.6",
		"@codemirror/language": "$@codemirror/language"
	},
	"trustedDependencies": []
}
